    {
      "type": "custom",
      "name": "Payroll Reports Generation",
      "desc": "Generate Monthly and Yearly Payroll Reports",
      "zones": [
        {
          "name": "Reports Generation",
          "layout": {
            "columns": 12,
            "spacing": 2
          },
          "components": [
            {
              "type": "form",
              "name": "ReportGenerationForm",
              "fields": [
                {
                  "field": "report_type",
                  "type": "select",
                  "required": true,
                  "options": [
                    {
                      "select_type": "static",
                      "select_options": [
                        {
                          "id": "monthly",
                          "name": "Monthly",
                          "value": "monthly"
                        },
                        {
                          "id": "yearly",
                          "name": "Yearly",
                          "value": "yearly"
                        }
                      ],
                      "provider": "payroll_reports",
                      "value_field": "id",
                      "label_field": "report_type"
                    }
                  ]
                }
              ],
              "submit": "generate"
            },
            {
              "type": "table",
              "name": "GeneratedReportsList",
              "provider": "payroll_reports",
              "cols": [
                {
                  "field": "report_type",
                  "header": "Report Type"
                },
                {
                  "field": "generated_on",
                  "header": "Generated On"
                }
              ],
              "actions": []
            }
          ]
        }
      ]
    }
  ],
  "views": [
    {
      "view_name": "monthly_salaries_report",
      "source_tables": [
        "payroll_records"
      ],
      "columns": [
        {
          "name": "month",
          "transformation": "DATE_TRUNC('month', pay_period_start)"
        },
        {
          "name": "total_salaries",
          "transformation": "SUM(gross_pay)"
        }
      ],
      "group_by": [
        "DATE_TRUNC('month', pay_period_start)"
      ],
      "filters": null,
      "description": "Aggregates total salaries per month"
    },
    {
      "view_name": "yearly_payroll_report",
      "source_tables": [
        "payroll_records"
      ],
      "columns": [
        {
          "name": "year",
          "transformation": "DATE_TRUNC('year', pay_period_start)"
        },
        {
          "name": "total_salaries",
          "transformation": "SUM(gross_pay)"
        }
      ],
      "group_by": [
        "DATE_TRUNC('year', pay_period_start)"
      ],
      "filters": null,
      "description": "Aggregates total salaries per year"
    },
    {
      "view_name": "monthly_deduction_report",
      "source_tables": [
        "payroll_records"
      ],
      "columns": [
        {
          "name": "month",
          "transformation": "DATE_TRUNC('month', pay_period_start)"
        },
        {
          "name": "total_deductions",
          "transformation": "SUM(deductions)"
        }
      ],
      "group_by": [
        "DATE_TRUNC('month', pay_period_start)"
      ],
      "filters": "pay_period_start IS NOT NULL",
      "description": "Aggregates total deductions per month"
    }
  ]
